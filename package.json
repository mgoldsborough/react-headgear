{
  "name": "react-headgear",
  "version": "0.0.1-alpha.1",
  "description": "The AI-native SEO library for React. Intent-based API, self-documenting types, built for agents.",
  "keywords": [
    "react",
    "seo",
    "meta",
    "head",
    "helmet",
    "og",
    "opengraph",
    "structured-data",
    "json-ld",
    "schema.org",
    "ai-native",
    "typescript"
  ],
  "author": "NimbleBrain",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NimbleBrainInc/react-headgear"
  },
  "homepage": "https://headgear.dev",
  "bugs": {
    "url": "https://github.com/NimbleBrainInc/react-headgear/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./schema": {
      "import": {
        "types": "./dist/schema/index.d.ts",
        "default": "./dist/schema/index.js"
      },
      "require": {
        "types": "./dist/schema/index.d.cts",
        "default": "./dist/schema/index.cjs"
      }
    },
    "./og": {
      "import": {
        "types": "./dist/og/index.d.ts",
        "default": "./dist/og/index.js"
      },
      "require": {
        "types": "./dist/og/index.d.cts",
        "default": "./dist/og/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "AI.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
